# API configuration (NestJS + Prisma/SQLite)

# Port the API listens on.
PORT=3000

# Prisma SQLite connection string. Relative paths resolve against the
# apps/api/prisma directory, so this points at the repo-root data/ folder.
# On Render, point this at a mounted persistent disk, e.g. file:/var/data/app.db
DATABASE_URL="file:../../../data/app.db"

# Browser origin allowed by CORS (the web app's dev URL).
CORS_ORIGIN=http://localhost:5173
