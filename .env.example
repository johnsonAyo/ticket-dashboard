# Root reference for all environment variables. Each app also has its own
# .env.example (apps/api/.env.example, apps/web/.env.example) that it loads.

# ---- apps/api (NestJS) ----
# Port the API listens on.
PORT=3000
# Prisma SQLite connection string. Relative paths resolve against apps/api.
# Locally the file lives in the repo `data/` dir; on Render point this at a
# mounted persistent disk, e.g. file:/var/data/app.db
DATABASE_URL="file:../../data/app.db"
# Browser origin allowed by CORS (the web app's dev URL).
CORS_ORIGIN=http://localhost:5173

# ---- apps/web (Vite React) ----
# Base URL the frontend uses to reach the API.
VITE_API_BASE_URL=http://localhost:3000/api
