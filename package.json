{
  "name": "ticket-dashboard",
  "version": "1.0.0",
  "private": true,
  "description": "Support ticket dashboard - full-stack assessment (Vite React + NestJS + Prisma/SQLite)",
  "license": "MIT",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "postinstall": "npm run build -w @ticket/shared && npm run prisma:generate -w @ticket/api",
    "dev": "npm run dev -w apps/api & npm run dev -w apps/web",
    "dev:api": "npm run dev -w apps/api",
    "dev:web": "npm run dev -w apps/web",
    "build": "npm run build -w @ticket/shared && npm run build -w apps/api && npm run build -w apps/web",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "eslint \"apps/**/src/**/*.{ts,tsx}\" \"packages/**/src/**/*.ts\"",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\"",
    "test": "npm run test -w apps/api",
    "test:e2e": "npm run test:e2e -w apps/web",
    "db:setup": "npm run db:setup -w apps/api",
    "db:migrate": "npm run db:migrate -w apps/api",
    "db:seed": "npm run db:seed -w apps/api"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1"
  },
  "engines": {
    "node": ">=20"
  }
}
